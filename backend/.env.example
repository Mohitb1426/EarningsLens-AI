# AWS Bedrock Configuration
USE_BEDROCK=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_SESSION_TOKEN=your-aws-session-token-here
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Voyage AI Embeddings
VOYAGE_API_KEY=your-voyage-api-key-here

# Server Configuration
PORT=8000

# ChromaDB Path
CHROMA_DB_PATH=../pipeline/data/chromadb

# Database Configuration (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./earningslens.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/earningslens

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
